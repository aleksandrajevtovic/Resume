MONGODB_URI=mongodb+srv://<db-username>:<db-password>@<cluster-host>/portfolio?retryWrites=true&w=majority&appName=Portfolio
JWT_SECRET=<base64-encoded-secret>
JWT_EXPIRATION_MS=86400000
ADMIN_USERNAME=<required-admin-username>
ADMIN_PASSWORD=<required-strong-admin-password>
CORS_ALLOWED_ORIGIN=https://<your-netlify-site>.netlify.app
CLOUDINARY_CLOUD_NAME=<your-cloudinary-cloud-name>
CLOUDINARY_API_KEY=<your-cloudinary-api-key>
CLOUDINARY_API_SECRET=<your-cloudinary-api-secret>
CLOUDINARY_FOLDER=portfolio
UPLOAD_DIR=/tmp/uploads
NETLIFY_RENDER_ORIGIN=https://<your-render-service>.onrender.com
